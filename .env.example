# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Stripe ────────────────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── ČÚZK WSDP (pouze na serveru — Supabase Edge Function Secrets) ─────────────
# Registrace: https://wsdp.cuzk.cz/WSDPServer/
# Tyto hodnoty NIKDY nevkládej do frontendu ani do gitu.
# Nastav je přes: supabase secrets set CUZK_USERNAME=... CUZK_PASSWORD=...
CUZK_USERNAME=
CUZK_PASSWORD=

# ── Resend (pouze na serveru — Supabase Edge Function Secrets) ────────────────
RESEND_API_KEY=re_...
